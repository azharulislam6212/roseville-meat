{{ 'section-multi-card.css' | asset_url | stylesheet_tag }}

 
{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    @media screen and (min-width: 992px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top_tab }}px;
        padding-bottom: {{ section.settings.padding_bottom_tab }}px;
      }
  }

    @media screen and (min-width: 1024px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
{%- endstyle -%}

{%- if section.settings.enable_divider -%}
  <div class="{{ section.settings.page_width }}">
    <div class="section-divider" style="--divider-color: {{ section.settings.divider_color }}"></div>
  </div>
{%- endif -%}

<div
  id="{{ section.settings.them_section_id |  default:"collage-section" }}"
  class="multi-card-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  {% if settings.animations_reveal_on_scroll %}
    data-cascade
  {% endif %}
>
  <div class="{{ section.settings.page_width }}">
    {%- unless section.settings.heading == blank -%}
      <div class="row">
        <div class="section--header  text-center col-12 m-auto">
          <div class="section--header__inner">
            {% if section.settings.pre_text != blank %}
              <p class="section--pre-text">{{ section.settings.pre_text }}</p>
            {% endif %}
            <h2 class="section--title inline-richtext {{ section.settings.heading_size }}">
              {{ section.settings.heading }}
            </h2>
          </div>
        </div>
      </div>
    {%- endunless -%}


    <div class="collage-multi-card">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'card' -%}
            <div class="multi-card" {{ block.shopify_attributes }}>
              <div class="multi-card__image"  style="--overlay-color: {{ block.settings.overlay_color }}; --shape-color: {{ block.settings.shape_color }} ">
                {% if block.settings.image != blank %}
                  {% render 'responsive-img' with image: block.settings.image %}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <div
                class="multi-card__content color-{{ block.settings.color_scheme }}   {{ block.settings.text_align }}"
                style=" --color-accent: {{ block.settings.color_accent.red }},{{ block.settings.color_accent.green }},{{ block.settings.color_accent.blue }};"
              >


                <collapsible-content {{ block.shopify_attributes }}>
               
                  
                    <details  class="disclosure disclosure--row" >
                      <summary>
                        <div class="disclosure-header">
                          <span class="disclosure__count">
                            {{- forloop.index  | prepend: '0'-}}
                          </span>

                          <h4 class="disclosure__title">
                            {{- block.settings.heading -}}
                          </h4>
                        </div>
                      </summary>
                      <div class="disclosure__panel has-motion">
                        <div class="disclosure__content rte">
                          <div class="row__content">
                                  {{ block.settings.text }}
                          </div>
                        </div>
                      </div>
                    </details>
                  
                
              </collapsible-content>


              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
