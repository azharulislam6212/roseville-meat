<!-- sections/our-approach.liquid -->
<div
  class="our-approach-section"
  style="margin: {{ section.settings.section_margin_top }}px 0 {{ section.settings.section_margin_bottom }}px;"
>
  <div
    class="approach-container"
    style="background: {{ section.settings.gradient_start }} linear-gradient(135deg, {{ section.settings.gradient_start }} 0%, {{ section.settings.gradient_end }} 100%);"
  >
    <div class="approach-content-container">
      <!-- Content Area -->
      <div class="approach-content">
        {% if section.settings.heading %}
          <h2
            class="approach-heading"
            style="color: {{ section.settings.color_scheme.settings.text }};"
          >
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description %}
          <div
            class="approach-description"
            style="color: {{ section.settings.color_scheme.settings.text }};"
          >
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      <!-- Images Section -->
      <div class="approach-images">
        {% if section.settings.image_1 %}
          <div class="approach-image-wrapper">
            <img
              src="{{ section.settings.image_1 | image_url: width:600, height:400, crop: 'center' }}"
              alt="{{ section.settings.image_1.alt | default: 'Approach image 1' }}"
              class="approach-image"
              loading="lazy"
              width="600"
              height="400"
            >
          </div>
        {% endif %}

        {% if section.settings.image_2 %}
          <div class="approach-image-wrapper">
            <img
              src="{{ section.settings.image_2 | image_url: width:600, height:400, crop: 'center' }}"
              alt="{{ section.settings.image_2.alt | default: 'Approach image 2' }}"
              class="approach-image"
              loading="lazy"
              width="600"
              height="400"
            >
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Approach",
  "settings": [
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient Start Color",
      "default": "#E8E5FF",
      "info": "Light purple/blue color for gradient start"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient End Color",
      "default": "#F5F5FF",
      "info": "Light color for gradient end"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Approached"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>At N-Deptskn, we believe in the power of nature combined with cutting-edge science. We meticulously select high-quality, natural, and potent ingredients, ensuring each formula is developed to deliver visible results for all skin types, tones, and textures. We are committed to transparency, purity, and sustainability, ensuring our products are not only effective but also gentle on your skin and the planet.</p>"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "First Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Second Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Top Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_margin_bottom",
      "label": "Bottom Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Our Approach",
      "category": "Custom"
    }
  ]
}
{% endschema %}
