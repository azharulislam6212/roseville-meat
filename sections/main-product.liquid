{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'marquee.css' | asset_url | stylesheet_tag }}

{% unless product.has_only_default_variant %}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{% endunless %}
{%- if product.quantity_price_breaks_configured? -%}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
         --color-accent: {{ section.settings.color_accent.red }},{{ section.settings.color_accent.green }},{{ section.settings.color_accent.blue }};
         --color-link: {{ section.settings.color_accent.red }},{{ section.settings.color_accent.green }},{{ section.settings.color_accent.blue }};
       }

     .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile}}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- if product.quantity_price_breaks_configured? -%}
  <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="product-wrapper section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {%- liquid
    if product == null
      assign placeholder = true
    endif

    assign first_3d_model = product.media | where: 'media_type', 'model'

    capture section_class
      echo 'product--gallery-type-' | append: section.settings.gallery_type | append: ' product--gallery-size-' | append: section.settings.gallery_image_size | append: ' ' | append: class
    endcapture

    if section.settings.gallery_size == '8'
      assign grid_left = 'col-lg-7 col-xl-8'
      assign grid_right = 'col-lg-5 col-xl-4'
    elsif section.settings.gallery_size == '7'
      assign grid_left = 'col-md-7'
      assign grid_right = 'col-md-5'
    elsif section.settings.gallery_size == '6'
      assign grid_left = 'col-md-6'
      assign grid_right = 'col-md-6'
    elsif section.settings.gallery_size == '5'
      assign grid_left = 'col-md-5'
      assign grid_right = 'col-md-7'
    else
      assign grid_left = 'col-md-6'
      assign grid_right = 'col-md-6'
    endif
  -%}

  {%- if first_3d_model -%}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{- 'component-model-viewer-ui.css' | asset_url -}}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {%- if product.media.size > 0 -%}
    {%- if section.settings.enable_zoom -%}
      <link rel="stylesheet" href="{{- 'photoswipe.css' | asset_url -}}" media="print" onload="this.media='all'">

      <script src="{{- 'photoswipe-lightbox.umd.min.js' | asset_url -}}" defer="defer" data-theme-script></script>
      <script src="{{- 'photoswipe.umd.min.js' | asset_url -}}" defer="defer" data-theme-script></script>
    {%- endif -%}

    <script src="{{- 'product-popup.js' | asset_url -}}" defer="defer" data-theme-script></script>
    <script src="{{- 'product-media.js' | asset_url -}}" defer="defer" data-theme-script></script>
  {%- endif -%}

  {%- capture thumbs_html -%}
    <div class="product__media-thumbs  {%- unless section.settings.gallery_type contains 'thumbs' %}   large-up-hide  {%- endunless -%}  {%- if section.settings.enable_mobile_thumbs == false %}  small-hide    medium-hide {%- endif -%}">
      <div class="swiper" data-thumbs>
        <div class="swiper-wrapper {%if  section.settings.gallery_type == 'thumbs-bottom'%} row-cols-5 {%- endif -%}">
          {%- for media in product.media -%}
          
  
            <div
              class="swiper-slide  {%if  section.settings.gallery_type == 'thumbs-bottom'%} col {%- endif -%}"
              data-thumbnail
            >
              {%- render 'product-thumbnail-custom', media: media, media_size: section.settings.gallery_image_size -%}
            </div>
          {%- endfor -%}
        </div>
        <div class="product__media-thumbs-arrows">
          <button class="button-arrow button-arrow--small product__media-thumbs-arrow product__media-thumbs-arrow--prev" data-thumbs-prev aria-label="previous">
            {%- if section.settings.gallery_type != 'thumbs-bottom' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 14L12 8L18 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>

            {%- else -%}
         <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 6L8 12L14 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>

            {%- endif -%}
          </button>
  
          <button class="button-arrow button-arrow--small product__media-thumbs-arrow product__media-thumbs-arrow--next" data-thumbs-next aria-label="next">
            {%- if section.settings.gallery_type != 'thumbs-bottom' -%}
               <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 10L12 16L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>

            {%- else -%}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 6L16 12L10 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>

            {%- endif -%}
          </button>
        </div><!-- /.product__media-thumbs-arrows -->
      </div>
    </div><!-- /.product__media-thumbs -->
  {%- endcapture -%}

  {%- style -%}
    #MainProduct-{{- section.id }} {
      {%- liquid
        assign partial_slide_ratio = 0.9
        assign slide_width = 100.0 | divided_by: section.settings.slides_per_view
        if section.settings.partial_slide
          assign slide_width = slide_width | times: partial_slide_ratio
        endif
      -%}

      --slide-width: {{ slide_width }}%;
    }
  {%- endstyle -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  <div class="product-block__wrapper  product {{ section_class }} js-main-product" id="MainProduct-{{- section.id }}">
    <div class="{{ section.settings.page_width }}">
      <div class="row product-row {% if section.settings.layout == 'text_first' %} flex-row-reverse {% endif %}">
        <div class="col-12  {{grid_left}}  {%if section.settings.enable_sticky_gallery %} product__gallery-sticky {% endif %}">
          {%- unless placeholder -%}
            <div class="product-gallery__wrapper">
              <product-media
                class="product__media"
                {% if section.settings.gallery_image_size == 'aspect-ratio' %}
                  data-slider-autoheight
                {% endif %}
                {% if section.settings.gallery_type contains 'grid' %}
                  data-slider-desktop-disabled
                {%- elsif section.settings.gallery_type != 'thumbs-bottom' -%}
                  data-thumbs-layout="{{- section.settings.gallery_type | remove: 'thumbs-' -}}"
                {% endif %}
              >
                {%- if product.media.size > 1 -%}
                  {%- if section.settings.gallery_type == 'thumbs-left' -%}
                    {{- thumbs_html -}}
                  {%- endif -%}

                  <div class="product__media-slider">
                    <div class="swiper product__swiper" data-slider>
                      <div class="product__media-track swiper-wrapper">
                        {%- for media in product.media -%}
                          <div
                            class="product__media-slide swiper-slide"
                            data-media-item
                            data-media-id="{{- media.id -}}"
                            data-index="{{- forloop.index0 -}}"
                          >
                            {%- render 'product-media-custom',
                              media: media,
                              product_ref: product,
                              preload_media: forloop.first,
                              media_size: section.settings.gallery_image_size,
                              disable_zoom_icon: section.settings.disable_zoom_icon,
                              enable_zoom: section.settings.enable_zoom
                            -%}
                          </div>
                          <!-- /.product__media-slide -->
                        {%- endfor -%}
                      </div>
                      <!-- /.product__media-track -->

                      {%- if section.settings.enable_navigation -%}
                        <div class="swiper-navigation">
                          <button
                            class="product__media-arrow button-arrow motion-reduce"
                            data-arrow-prev
                            aria-label="previous"
                          >
                            <svg
                              width="12"
                              height="9"
                              viewBox="0 0 12 9"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M11.1667 4C11.4428 4 11.6667 4.22387 11.6667 4.5C11.6667 4.77613 11.4428 5 11.1667 5H5V8.5C5 8.70226 4.8782 8.88453 4.69133 8.96193C4.50453 9.03933 4.28945 8.9966 4.14645 8.8536L0.146447 4.8536C0.05268 4.7598 0 4.6326 0 4.5C0 4.3674 0.05268 4.2402 0.146447 4.14646L4.14645 0.14646C4.28945 0.00345997 4.50453 -0.0393134 4.69133 0.0380733C4.8782 0.115467 5 0.297787 5 0.500013V4H11.1667Z" fill="currentColor"></path>
                            </svg>
                          </button>

                          <button
                            class="product__media-arrow button-arrow motion-reduce"
                            data-arrow-next
                            aria-label="next"
                          >
                            <svg
                              width="12"
                              height="9"
                              viewBox="0 0 12 9"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M0.500082 4C0.223948 4 8.2016e-05 4.22387 8.2016e-05 4.5C8.2016e-05 4.77613 0.223948 5 0.500082 5H6.66675V8.5C6.66675 8.70226 6.78855 8.88453 6.97542 8.96193C7.16222 9.03933 7.3773 8.9966 7.5203 8.8536L11.5203 4.8536C11.6141 4.7598 11.6667 4.6326 11.6667 4.5C11.6667 4.3674 11.6141 4.2402 11.5203 4.14646L7.5203 0.14646C7.3773 0.00345997 7.16222 -0.0393134 6.97542 0.0380733C6.78855 0.115467 6.66675 0.297787 6.66675 0.500013V4H0.500082Z" fill="currentColor"></path>
                            </svg>
                          </button>
                        </div>
                        <!-- /.swiper-navigation -->
                      {%- endif -%}

                      <div class="swiper-pagination"></div>
                    </div>
                  </div>
                  <!-- /.product__media-slider -->

                  {%- if section.settings.gallery_type == 'thumbs-bottom'
                    or section.settings.gallery_type == 'thumbs-right'
                  -%}
                    {{- thumbs_html -}}
                  {%- endif -%}

                  {%- unless section.settings.gallery_type contains 'thumbs'
                    or section.settings.enable_mobile_thumbs == false
                  -%}
                    {{- thumbs_html -}}
                  {%- endunless -%}

                {%- else -%}
                  <div class="product__media-slider">
                    {%- render 'product-media-custom',
                      media: product.featured_media,
                      product_ref: product,
                      media_size: section.settings.gallery_image_size,
                      disable_zoom_icon: section.settings.disable_zoom_icon,
                      enable_zoom: section.settings.enable_zoom
                    -%}
                  </div>
                  <!-- /.product__media-slider -->
                {%- endif -%}
              </product-media>
            </div>
          {%- else -%}
            <div class="product__media-item">
              <div
                class="product-media-container global-media-settings gradient{% if section.settings.constrain_to_viewport %} constrain-height{% endif %}"
                style="--ratio: 1.0; --preview-ratio: 1.0;"
              >
                {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
          {%- endunless -%}

          {% assign free_trial = section.blocks | where: 'type', 'free_trial' %}
          {%- for block in free_trial -%}
            <div class="free-trial-flex free-trial-desktop" {{ block.shopify_attributes }}>
              {% if block.settings.trial_icon != blank %}
                <span class="trial__icon">
                  {% render 'icon-img' with image: block.settings.trial_icon %}
                </span>
              {% endif %}
              <div>
                {% if block.settings.title %}
                  <h3 class="trial__title">{{ block.settings.title }}</h3>
                {% endif %}

                <p class="trial_text">{{ block.settings.text }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="col-12 {{ grid_right }}">
          <section
            id="ProductInfo-{{ section.id }}"
            class="product__info-container {% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
          >
            {%- assign product_form_id = 'product-form-' | append: section.id -%}

            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'tags' -%}
                  <div class="tag-list">
                    <li>
                      <span class="product-tag">{{ block.settings.tag_1 }}</span>
                    </li>
                    <li>
                      <span class="product-tag product-tag--shipping">
                        {%- if block.settings.tag_2 contains 'shipping'
                          or block.settings.tag_2 contains 'SHIPPING'
                          or block.settings.tag_2 contains 'Shipping'
                        -%}
                          <svg
                            width="12"
                            height="12"
                            viewBox="0 0 12 12"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M11.9597 5.41594L11.3034 3.77531C11.2342 3.60129 11.1142 3.45214 10.959 3.3473C10.8039 3.24245 10.6207 3.18677 10.4334 3.1875H9.1875V3C9.1875 2.85082 9.12824 2.70774 9.02275 2.60225C8.91726 2.49676 8.77418 2.4375 8.625 2.4375H1.5C1.25136 2.4375 1.0129 2.53627 0.837087 2.71209C0.661272 2.8879 0.5625 3.12636 0.5625 3.375V8.625C0.5625 8.87364 0.661272 9.1121 0.837087 9.28791C1.0129 9.46373 1.25136 9.5625 1.5 9.5625H2.15906C2.27541 9.89147 2.49087 10.1763 2.77579 10.3777C3.0607 10.5792 3.40106 10.6874 3.75 10.6874C4.09894 10.6874 4.4393 10.5792 4.72421 10.3777C5.00913 10.1763 5.22459 9.89147 5.34094 9.5625H7.40906C7.52541 9.89147 7.74087 10.1763 8.02579 10.3777C8.3107 10.5792 8.65106 10.6874 9 10.6874C9.34894 10.6874 9.6893 10.5792 9.97421 10.3777C10.2591 10.1763 10.4746 9.89147 10.5909 9.5625H11.0625C11.3111 9.5625 11.5496 9.46373 11.7254 9.28791C11.9012 9.1121 12 8.87364 12 8.625V5.625C11.9939 5.55409 11.9804 5.48402 11.9597 5.41594ZM9.1875 4.3125H10.3069L10.6069 5.0625H9.1875V4.3125ZM3.75 9.5625C3.63875 9.5625 3.52999 9.52951 3.43749 9.4677C3.34499 9.40589 3.27289 9.31804 3.23032 9.21526C3.18774 9.11248 3.1766 8.99938 3.19831 8.89026C3.22001 8.78115 3.27359 8.68092 3.35225 8.60225C3.43092 8.52359 3.53115 8.47001 3.64026 8.44831C3.74938 8.4266 3.86248 8.43774 3.96526 8.48032C4.06804 8.52289 4.15589 8.59499 4.2177 8.68749C4.27951 8.77999 4.3125 8.88875 4.3125 9C4.3125 9.14918 4.25324 9.29226 4.14775 9.39775C4.04226 9.50324 3.89918 9.5625 3.75 9.5625ZM8.0625 7.5975C7.76052 7.80048 7.53152 8.09487 7.40906 8.4375H5.34094C5.22459 8.10853 5.00913 7.82371 4.72421 7.62227C4.4393 7.42082 4.09894 7.31265 3.75 7.31265C3.40106 7.31265 3.0607 7.42082 2.77579 7.62227C2.49087 7.82371 2.27541 8.10853 2.15906 8.4375H1.6875V6.5625H8.0625V7.5975ZM8.0625 5.4375H1.6875V3.5625H8.0625V5.4375ZM9 9.5625C8.88875 9.5625 8.77999 9.52951 8.68749 9.4677C8.59499 9.40589 8.52289 9.31804 8.48032 9.21526C8.43774 9.11248 8.4266 8.99938 8.44831 8.89026C8.47001 8.78115 8.52359 8.68092 8.60225 8.60225C8.68092 8.52359 8.78115 8.47001 8.89026 8.44831C8.99938 8.4266 9.11248 8.43774 9.21526 8.48032C9.31804 8.52289 9.40589 8.59499 9.4677 8.68749C9.52951 8.77999 9.5625 8.88875 9.5625 9C9.5625 9.14918 9.50324 9.29226 9.39775 9.39775C9.29226 9.50324 9.14918 9.5625 9 9.5625ZM10.875 8.4375H10.5909C10.4848 8.139 10.297 7.8763 10.0489 7.67931C9.80074 7.48232 9.50229 7.35896 9.1875 7.32328V6.1875H10.875V8.4375Z" fill="currentColor"/>
                          </svg>
                        {%- endif -%}

                        {{ block.settings.tag_2 }}
                      </span>
                    </li>
                  </div>

                {%- when 'vendor' -%}
                  <p
                    class="product__text-vendor inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.text -}}
                  </p>

                {%- when 'product_description' -%}
                  {% if block.settings.text != blank %}
                    <div
                      class="product__description inline-richtext {% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      {{- block.settings.text -}}
                    </div>
                  {% endif %}

                {%- when 'free_trial' -%}
                  <div class="free-trial-flex free-trial-mobile" {{ block.shopify_attributes }}>
                    {% if block.settings.trial_icon != blank %}
                      <span class="trial__icon">
                        {% render 'icon-img' with image: block.settings.trial_icon %}
                      </span>
                    {% endif %}
                    <div>
                      {% if block.settings.title %}
                        <h3 class="trial__title">{{ block.settings.title }}</h3>
                      {% endif %}

                      <p class="trial_text">{{ block.settings.text }}</p>
                    </div>
                  </div>
                {%- when 'author' -%}
                  <div class="author__box" {{ block.shopify_attributes }}>
                    {% if block.settings.author_img != blank %}
                      <span class="author__box__image">
                        {% render 'responsive-img' with image: block.settings.author_img %}
                      </span>
                    {% endif %}
                    <div>
                      {% if block.settings.title %}
                        <h3 class="author__box__title">{{ block.settings.title }}</h3>
                      {% endif %}

                      <p class="author__box__text">{{ block.settings.text }}</p>
                      <p class="author__box__name">{{ block.settings.author_author }}</p>
                    </div>
                  </div>

                {%- when 'text' -%}
                  <p
                    class="product__text inline-richtext {% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.text -}}
                  </p>
                {%- when 'trust_pilot_review' -%}
                  <div class="trustpilot-review" {{ block.shopify_attributes }}>
                    {% if block.settings.review_icon != blank %}
                      <span class="trustpilot__icon">
                        {% render 'icon-img' with image: block.settings.review_icon %}
                      </span>
                    {% endif %}
                    <span>
                      {{ block.settings.text }}
                    </span>
                  </div>

                {%- when 'subscription' -%}

           
   
                  <purchase-options  id="purchase-options-{{ section.id }}" >

                     {% assign current_variant = product.selected_or_first_available_variant %}

                      <!-- Subscription -->
                    {% if current_variant.selling_plan_allocations.size > 0 %}
 
                  <div class="purchase-wrapper">

                    <!-- One Time Purchase -->
                    {% unless product.requires_selling_plan %}
                    <label class="purchase-card one-time active">
                      <div class="purchase-header">
                        <div class="left radio-label">
                          <input
                            type="radio"
                            name="purchase_option"
                            value=""
                            checked
                            class="purchase-option"
                          >
                          <span>One Time Purchase</span>
                        </div>

                        <div class="right">
                          <strong>{{ current_variant.price | money }}</strong>
                        </div>
                      </div>
                    </label>
                    {% endunless %}

                   
                      {% assign allocation = current_variant.selling_plan_allocations.first %}
                      {% assign plan_group = product.selling_plan_groups.first %}

                      {% assign save = current_variant.price | minus: allocation.price %}
                      {% assign save_percent = save | times: 100 | divided_by: current_variant.price %}

                      <div class="subscription-box">

                      

                        <label class="purchase-card subscribe">

                          <span class="most-chosen">
                          MOST CHOSEN
                        </span>

                          <div class="purchase-header">

                            <div class="left radio-label">

                              <input
                                type="radio"
                                name="purchase_option"
                                value="{{ allocation.selling_plan.id }}"
                                class="purchase-option"
                              >

                              <div>

                                <div class="title-row">

                                  <h4>{{ plan_group.name }}</h4>

                                  <span class="save-badge">
                                    SAVE {{ save_percent }}%
                                  </span>

                                </div>

                                <p class="subscription-save-text">
                                  Save {{ save | money }} today and on every shipment
                                </p>

                              </div>

                            </div>

                            <div class="price">

                              <div class="sale-price">
                                {{ allocation.price | money }}
                              </div>

                              <div class="compare-price">
                                {{ current_variant.price | money }}
                              </div>

                            </div>

                          </div>

                          <!-- Delivery -->

                          <div class="delivery-row">
 


                             <label for="selling-plan-select">Deliver Every</label>
                                        

                             <div class="custom-select">

                            
                            <select id="selling-plan-select">

