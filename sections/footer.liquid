{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'marquee.css' | asset_url | stylesheet_tag }}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom:{{ section.settings.padding_bottom_moblie }}px;
  }

  @media screen and (min-width: 769px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient">
  {% if section.settings.bg_image != blank %}
    <div class="footer__bg">
      {% render 'responsive-img' with image: section.settings.bg_image , class:"desktop__image" %}
      {% if section.settings.bg_image_mobile != blank %}
        {% render 'responsive-img' with image: section.settings.bg_image_mobile class:"mobile__image" %}
      {% else %}
        {% render 'responsive-img' with image: section.settings.bg_image  class:"mobile__image" %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}

  {% assign marquee_text = section.blocks | where: 'type', 'marquee_text' %}
  {%- if marquee_text.size > 0 -%}
    <div class="footer-marquee running-content marquee">
      <marquee-content
        data-speed="{{ section.settings.speed }}"
        class="running-content-wrap"
        style="--marquee-duration: {{ 1000 | divided_by: section.settings.speed }}s;"
      >
        {%- capture marquee_item -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'marquee_text' -%}
            <div class="running-content-item running-content-text  running-content-footer rte"  {{ block.shopify_attributes }}>
             

            {% if block.settings.image != blank %}

              <div class="running-img-footer" style="--image-width: {{ block.settings.image_width |  append: 'px'}}">
                {% render 'responsive-img' with image: block.settings.image %}
              </div>
      
            {% endif %}
            
              {{- block.settings.svg_icon -}}
              {{- block.settings.text -}}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    {%- endcapture -%}
        <div class="marquee-container js-marquee-items {{ section.settings.pause_when_hover | default: '' | replace: 'true', 'marquee--animation-pause' }}">
          {%- case section.blocks.size -%}
            {%- when 1 -%}
              {%- for i in (1..12) -%}
                <div class="js-marquee-item marquee-item  marquee__items--animate  marquee--{{- section.settings.moving_direction }}">
                  {{- marquee_item -}}
                </div>
              {%- endfor -%}
            {%- when 2, 3 -%}
              {%- for i in (1..7) -%}
                <div class="js-marquee-item marquee-item marquee__items--animate  marquee--{{- section.settings.moving_direction }}">
                  {{- marquee_item -}}
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..5) -%}
                <div class="js-marquee-item marquee-item  marquee__items--animate marquee--{{- section.settings.moving_direction }}">
                  {{- marquee_item -}}
                </div>
              {%- endfor -%}
          {%- endcase -%}
        </div>
      </marquee-content>
    </div>
  {% endif %}

  {%- if section.blocks.size > 0
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      {% if section.settings.layout contains 'grid' %}
        {% capture layout_class %}
          row row-cols-{{ section.settings.column_mobile }} row-cols-sm-{{ section.settings.column_tab }} row-cols-lg-{{ section.settings.column}}
        {% endcapture %}
      {% else %}
        {% capture layout_class %}
        fixed-layout
      {% endcapture %}
      {% endif %}

      <div class="footer__content-top  {% unless section.settings.layout contains 'box' %} section-{{ section.id }}-padding {% endunless %}">
        <div class="{{ section.settings.page_width }} layout-type--{{ section.settings.layout }}">
          {% if section.settings.layout contains 'box' %}
            <div class="box-row">
              <div
                class="box-left__content section-{{ section.id }}-padding"
              >
                {%- for block in section.blocks -%}
                  {%- case block.type -%}
                    {%- when 'text' -%}
                      <div
                        class="footer-block footer-block--{{ block.type }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {{ block.shopify_attributes }}
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ forloop.index }};"
                        {% endif %}
                      >
                        {%- if block.settings.image != blank -%}
                          {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ block.settings.image_width }}px);"
                          >
                            <img
                              srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                              src="{{ block.settings.image | image_url: width: 760 }}"
                              alt="{{ block.settings.image.alt | escape }}"
                              loading="lazy"
                              width="{{ block.settings.image.width }}"
                              height="{{ block.settings.image.height }}"
                            >
                          </div>
                        {%- endif -%}
                        {%- if block.settings.heading != blank -%}
                          <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                        {%- endif -%}
                        {% if block.settings.subtext != blank %}
                          <div class="footer-block__details-text rte">
                            {{ block.settings.subtext }}
                          </div>
                        {% endif %}

                        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                          <div class="footer__follow-on-shop">
                            {{ shop | login_button: action: 'follow' }}
                          </div>
                        {%- endif -%}

                        {%- if block.settings.show_social and has_social_icons -%}
                          <div class="social-info">
                            <span>Follow Us</span>
                            {%- render 'social-icons', class: 'footer__list-social' -%}
                          </div>
                        {%- endif -%}
                      </div>

                    {%- when 'newslatter' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}

                      <div class="footer-block__newsletter">
                        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter_form' -%}
                          <input type="hidden" name="contact[tags]" value="newsletter">
                          <div class="newsletter-form__group-wrapper">
                            <div class="newsletter-form__group">
                              <label
                                class="newsletter-form__field visually-hidden"
                                for="NewsletterForm--{{ section.id }}"
                              >
                                {{ 'newsletter.label' | t }}
                              </label>

                              <input
                                id="NewsletterForm--{{ section.id }}"
                                type="email"
                                name="contact[email]"
                                class="newsletter-form__input"
                                value="{{ form.email }}"
                                aria-required="true"
                                autocorrect="off"
                                autocapitalize="off"
                                autocomplete="email"
                                {% if form.errors %}
                                  autofocus
                                  aria-invalid="true"
                                  aria-describedby="ContactFooter-error"
                                {% elsif form.posted_successfully? %}
                                  aria-describedby="ContactFooter-success"
                                {% endif %}
                                placeholder="{{ 'newsletter.label' | t }}"
                                required
                              >

                              <button
                                type="submit"
                                class="newsletter-button"
                                name="commit"
                                id="Subscribe"
                                aria-label="{{ 'newsletter.button_label' | t }}"
                              >
                                <span>{{ 'newsletter.button_label' | t }}</span>
                                <span class="svg-icon">
                                  <svg
                                    width="16"
                                    height="17"
                                    viewBox="0 0 16 17"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                  >
                                    <path d="M1.74941 8.5003C1.74941 8.30139 1.82843 8.11062 1.96908 7.96997C2.10973 7.82932 2.3005 7.7503 2.49941 7.7503L11.6869 7.7503L8.46691 4.53093C8.32601 4.39003 8.24686 4.19893 8.24686 3.99968C8.24686 3.80042 8.32601 3.60932 8.46691 3.46843C8.60781 3.32753 8.7989 3.24838 8.99816 3.24838C9.19742 3.24838 9.38851 3.32753 9.52941 3.46843L14.0294 7.96843C14.0993 8.0381 14.1548 8.1209 14.1927 8.21206C14.2305 8.30323 14.25 8.40097 14.25 8.49968C14.25 8.59839 14.2305 8.69613 14.1927 8.78729C14.1548 8.87845 14.0993 8.96125 14.0294 9.03093L9.52941 13.5309C9.45964 13.6007 9.37682 13.656 9.28567 13.6938C9.19452 13.7315 9.09682 13.751 8.99816 13.751C8.8995 13.751 8.8018 13.7315 8.71065 13.6938C8.6195 13.656 8.53667 13.6007 8.46691 13.5309C8.39714 13.4612 8.3418 13.3783 8.30405 13.2872C8.26629 13.196 8.24686 13.0983 8.24686 12.9997C8.24686 12.901 8.26629 12.8033 8.30405 12.7122C8.3418 12.621 8.39714 12.5382 8.46691 12.4684L11.6869 9.2503L2.49941 9.2503C2.3005 9.2503 2.10973 9.17128 1.96908 9.03063C1.82843 8.88998 1.74941 8.69921 1.74941 8.5003Z" fill="currentColor"/>
                                  </svg>
                                </span>
                              </button>
                            </div>
                            {%- if form.errors -%}
                              <small class="newsletter-form__message form__message" id="ContactFooter-error">
                                <span class="svg-wrapper">
                                  {{- 'icon-error.svg' | inline_asset_content -}}
                                </span>
                                {{- form.errors.translated_fields.email | capitalize }}
                                {{ form.errors.messages.email -}}
                              </small>
                            {%- endif -%}
                          </div>
                          {%- if form.posted_successfully? -%}
                            <h3
                              class="newsletter-form__message newsletter-form__message--success form__message"
                              id="ContactFooter-success"
                              tabindex="-1"
                              autofocus
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-success.svg' | inline_asset_content -}}
                              </span>
                              {{- 'newsletter.success' | t }}
                            </h3>
                          {%- endif -%}
                        {%- endform -%}

                        {% if block.settings.text != blank %}
                          <p class="footer-block_newsletter-text">
                            {{ block.settings.text }}
                          </p>
                        {% endif %}
                      </div>
                  {%- endcase -%}
                {%- endfor -%}
              </div>

              <div class="box-right__content section-{{ section.id }}-padding">
                {%- for block in section.blocks -%}
                  {% unless block.type == 'marquee_text' or block.type == 'text' or block.type == 'newslatter' %}
                    <div
                      class="footer-block  {% if section.settings.layout contains "grid" %} col  {% endif %}  footer-block--{{ block.type }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {{ block.shopify_attributes }}
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                  {% endunless %}
                  {%- case block.type -%}
                    {%- when '@app' -%}
                      {% render block %}
                    {%- when 'link_list' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      {%- if block.settings.menu != blank -%}
                        <ul class="footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li>
                              <a
                                href="{{ link.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                {{ link.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- when 'product_list' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      {%- if block.settings.product_list != blank -%}
                        {% assign product_list = block.settings.product_list %}

                        <ul class="footer-block__details-content list-unstyled">
                          {%- for product in product_list -%}
                            <li>
                              <a
                                href="{{ product.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                {% if product.featured_image != blank %}
                                  <div class="product-thumb-img">
                                    {{
                                      product.featured_image
                                      | image_url: width: 2000
                                      | image_tag:
                                        loading: 'lazy',
                                        widths: '200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000',
                                        sizes: sizes,
                                        class: class,
                                        alt: product.title
                                    }}
                                  </div>
                                {% endif %}
                                {{ product.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- when 'brand_information' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      <div class="footer-block__brand-info">
                        {%- if settings.brand_image != blank -%}
                          {%- assign brand_image_height = settings.brand_image_width
                            | divided_by: settings.brand_image.aspect_ratio
                          -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                          >
                            {{
                              settings.brand_image
                              | image_url: width: 1100
                              | image_tag:
                                loading: 'lazy',
                                widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                                height: brand_image_height,
                                width: settings.brand_image_width
                            }}
                          </div>
                        {%- endif -%}
                        {%- if settings.brand_headline != blank -%}
                          <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                        {%- endif -%}
                        {%- if settings.brand_description != blank -%}
                          <div class="rte">{{ settings.brand_description }}</div>
                        {%- endif -%}
                        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                          <div class="footer__follow-on-shop">
                            {{ shop | login_button: action: 'follow' }}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.show_social and has_social_icons -%}
                          <div class="social-info">
                            <span>Follow Us :</span>
                            {%- render 'social-icons', class: 'footer__list-social' -%}
                          </div>
                        {%- endif -%}
                      </div>
                    {%- when 'image' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      <div class="footer-block__details-content text-{{ block.settings.alignment }}">
                        {%- if block.settings.image != blank -%}
                          {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ block.settings.image_width }}px);"
                          >
                            <img
                              srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                              src="{{ block.settings.image | image_url: width: 760 }}"
                              alt="{{ block.settings.image.alt | escape }}"
                              loading="lazy"
                              width="{{ block.settings.image.width }}"
                              height="{{ block.settings.image.height }}"
                            >
                          </div>
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                        {%- endif -%}
                      </div>
                  {%- endcase -%}

                  {% unless block.type == 'marquee_text' or block.type == 'text' or block.type == 'newslatter' %}
                    </div>
                  {% endunless %}
                {%- endfor -%}
              </div>
            </div>

          {% else %}
            {%- if section.blocks.size > 0 -%}
              <div
                class="footer__blocks-wrapper {{ layout_class }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                {% endif %}
              >
                {%- for block in section.blocks -%}
                  {% unless block.type == 'marquee_text' %}
                    <div
                      class="footer-block  {% if section.settings.layout contains "grid" %} col  {% endif %}  footer-block--{{ block.type }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {{ block.shopify_attributes }}
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                  {% endunless %}
                  {%- case block.type -%}
                    {%- when '@app' -%}
                      {% render block %}
                    {%- when 'text' -%}
                      <div
                        class="footer-block footer-block--{{ block.type }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {{ block.shopify_attributes }}
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ forloop.index }};"
                        {% endif %}
                      >
                        {%- if block.settings.image != blank -%}
                          {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ block.settings.image_width }}px);"
                          >
                            <img
                              srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                              src="{{ block.settings.image | image_url: width: 760 }}"
                              alt="{{ block.settings.image.alt | escape }}"
                              loading="lazy"
                              width="{{ block.settings.image.width }}"
                              height="{{ block.settings.image.height }}"
                            >
                          </div>
                        {%- endif -%}
                        {%- if block.settings.heading != blank -%}
                          <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                        {%- endif -%}
                        {% if block.settings.subtext != blank %}
                          <div class="footer-block__details-text rte">
                            {{ block.settings.subtext }}
                          </div>
                        {% endif %}

                        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                          <div class="footer__follow-on-shop">
                            {{ shop | login_button: action: 'follow' }}
                          </div>
                        {%- endif -%}

                        {%- if block.settings.show_social and has_social_icons -%}
                          <div class="social-info">
                            <span>Follow Us</span>
                            {%- render 'social-icons', class: 'footer__list-social' -%}
                          </div>
                        {%- endif -%}
                      </div>

                    {%- when 'product_list' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      {%- if block.settings.product_list != blank -%}
                        {% assign product_list = block.settings.product_list %}

                        <ul class="footer-block__details-content list-unstyled">
                          {%- for product in product_list -%}
                            <li>
                              <a
                                href="{{ product.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                {% if product.featured_image != blank %}
                                  <div class="product-thumb-img">
                                    {% render 'responsive-img', image: product.featured_image %}
                                  </div>
                                {% endif %}
                                {{ product.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- when 'link_list' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      {%- if block.settings.menu != blank -%}
                        <ul class="footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li>
                              <a
                                href="{{ link.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                {{ link.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                    {%- when 'brand_information' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      <div class="footer-block__brand-info">
                        {%- if settings.brand_image != blank -%}
                          {%- assign brand_image_height = settings.brand_image_width
                            | divided_by: settings.brand_image.aspect_ratio
                          -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                          >
                            {{
                              settings.brand_image
                              | image_url: width: 1100
                              | image_tag:
                                loading: 'lazy',
                                widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                                height: brand_image_height,
                                width: settings.brand_image_width
                            }}
                          </div>
                        {%- endif -%}
                        {%- if settings.brand_headline != blank -%}
                          <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                        {%- endif -%}
                        {%- if settings.brand_description != blank -%}
                          <div class="rte">{{ settings.brand_description }}</div>
                        {%- endif -%}
                        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                          <div class="footer__follow-on-shop">
                            {{ shop | login_button: action: 'follow' }}
                          </div>
                        {%- endif -%}

                        {%- if block.settings.show_social and has_social_icons -%}
                          <div class="social-info">
                            <span>Follow Us :</span>
                            {%- render 'social-icons', class: 'footer__list-social' -%}
                          </div>
                        {%- endif -%}
                      </div>
