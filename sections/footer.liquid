                                    </svg>
                                  </span>
                                {% else %}
                                  <span> Address:</span>
                                {% endif %}
                                <div class="address_content">{{ block.settings.address }}</div>
                              </li>
                            {% endif %}
                          </ul>
                        {% endif %}
                      </div>

                    {%- when 'newslatter' -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                      {%- endif -%}
                      {% if block.settings.text != blank %}
                        <p class="footer-block_newsletter-text">
                          {{ block.settings.text }}
                        </p>
                      {% endif %}

                      <div class="footer-block__newsletter">
                        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter_form' -%}
                          <input type="hidden" name="contact[tags]" value="newsletter">
                          <div class="newsletter-form__group-wrapper">
                            <div class="newsletter-form__group">
                              <label
                                class="newsletter-form__field visually-hidden"
                                for="NewsletterForm--{{ section.id }}"
                              >
                                {{ 'newsletter.label' | t }}
                              </label>

                              <input
                                id="NewsletterForm--{{ section.id }}"
                                type="email"
                                name="contact[email]"
                                class="newsletter-form__input"
                                value="{{ form.email }}"
                                aria-required="true"
                                autocorrect="off"
                                autocapitalize="off"
                                autocomplete="email"
                                {% if form.errors %}
                                  autofocus
                                  aria-invalid="true"
                                  aria-describedby="ContactFooter-error"
                                {% elsif form.posted_successfully? %}
                                  aria-describedby="ContactFooter-success"
                                {% endif %}
                                placeholder="{{ 'newsletter.label' | t }}"
                                required
                              >

                              <button
                                type="submit"
                                class="newsletter-button button button--secondary"
                                name="commit"
                                id="Subscribe"
                                aria-label="{{ 'newsletter.button_label' | t }}"
                              >
                                <span>Sign In</span>
                              </button>
                            </div>
                            {%- if form.errors -%}
                              <small class="newsletter-form__message form__message" id="ContactFooter-error">
                                <span class="svg-wrapper">
                                  {{- 'icon-error.svg' | inline_asset_content -}}
                                </span>
                                {{- form.errors.translated_fields.email | capitalize }}
                                {{ form.errors.messages.email -}}
                              </small>
                            {%- endif -%}
                          </div>
                          {%- if form.posted_successfully? -%}
                            <h3
                              class="newsletter-form__message newsletter-form__message--success form__message"
                              id="ContactFooter-success"
                              tabindex="-1"
                              autofocus
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-success.svg' | inline_asset_content -}}
                              </span>
                              {{- 'newsletter.success' | t }}
                            </h3>
                          {%- endif -%}
                        {%- endform -%}
                      </div>
                  {%- endcase -%}

                  {% unless block.type == 'marquee_text' or block.type == 'store_info' or block.type == 'text' %}
                    </div>
                  {% endunless %}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {% endif %}
        </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

