{% comment %}
Usage:
{% render 'responsive-img', image: image, class: 'product-image' %}
{% endcomment %}

{%- if sizes == blank -%}
  {%- assign sizes = '(min-width: 2000px) 1000px, (min-width: 1440px) 50vw, (min-width: 1200px) calc(100vw / 1.75), (min-width: 1000px) calc(100vw / 1.5), (min-width: 750px) calc(100vw / 3), 100vw' -%}
{%- endif -%}

{{
  image
  | image_url: width: 2000
  | image_tag:
    loading: 'lazy',
    widths: '200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000',
    sizes: sizes,
    class: class
}}
