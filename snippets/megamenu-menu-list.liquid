<div class="header__inline-mega-menu">
  <div class="{{ section.settings.page_width }}">
    <div class="mega-menu__innner color-{{ section.settings.mega_color_scheme }} gradient">
      <div class="row row-cols-1 row-cols-md-4 row-cols-lg-4">
        {%- if link.links.size > 0 -%}
          {%- for childlink in link.links -%}
            <div class="col">
              <a href="{{ childlink.url }}" class="mega-menu-title">{{ childlink.title | escape }}</a>
              <ul class="megamenu-list">
                {%- for grandchild in childlink.links -%}
                  <li>
                    <a href="{{ grandchild.url }}" class="link-animation">{{ grandchild.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endfor -%}
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'menu_block' -%}
              <div class="col">

                <h3 class="mega-menu-title">{{ block.settings.quick_menu_title | escape }}</h3>

                {%- if block.settings.block_menu != blank -%}
                  <ul class="megamenu-list">
                    {% for link in linklists[block.settings.block_menu].links %}
                      <li>
                        <a href="{{ link.url }}" class="link-animation">{{ link.title | escape }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {%- endif -%}

                {%- if  block.settings.enable_promotion -%}
                  
           

                {%- if block.settings.link_url != blank -%}
                  <a href="{{ block.settings.link_url }}" class="mega-link"> 
                {%- endif -%}
                

                    <div class="mega-image__card color-{{ block.settings.promotion_color_scheme }} gradient">
                          <div class="mega-image__img">

                          {%- if block.settings.image != blank -%}
                             {% render 'responsive-img' with image: block.settings.image %}

                             {%- else -%}
                              
                                 {{ "detailed-apparel-1" | placeholder_svg_tag: 'placeholder-svg' }}
                          {%- endif -%}
                           
                          </div>
                          <div class="mega-image__text link-animation">
                            {{ block.settings.link_text }}
                            <svg width="11" height="9" viewBox="0 0 11 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M10.372 4.68477L6.43453 8.62228C6.35244 8.70437 6.2411 8.75049 6.125 8.75049C6.0089 8.75049 5.89756 8.70437 5.81547 8.62228C5.73338 8.54018 5.68726 8.42884 5.68726 8.31274C5.68726 8.19665 5.73338 8.08531 5.81547 8.00321L9.00648 4.81274H0.4375C0.321468 4.81274 0.210188 4.76665 0.128141 4.6846C0.0460937 4.60256 0 4.49128 0 4.37524C0 4.25921 0.0460937 4.14793 0.128141 4.06588C0.210188 3.98384 0.321468 3.93774 0.4375 3.93774H9.00648L5.81547 0.747275C5.73338 0.665182 5.68726 0.55384 5.68726 0.437743C5.68726 0.321647 5.73338 0.210305 5.81547 0.128212C5.89756 0.0461192 6.0089 0 6.125 0C6.2411 0 6.35244 0.0461192 6.43453 0.128212L10.372 4.06571C10.4127 4.10634 10.445 4.1546 10.467 4.20771C10.489 4.26082 10.5003 4.31775 10.5003 4.37524C10.5003 4.43274 10.489 4.48967 10.467 4.54278C10.445 4.59589 10.4127 4.64414 10.372 4.68477Z" fill="currentColor"/>
                            </svg>
                            </div>
                    </div>
                  {%- if block.settings.link_url != blank -%}
                                  </a>
                  {%- endif -%}

                       {%- endif -%}
                 
              </div>
          {%- endcase -%}
        {% endfor %}
      </div>
    </div>
  </div>
</div>
