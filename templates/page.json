{
  "sections": {
    "section-page-header": {
      "type": "section-page-header",
      "settings": {
        "allow_transparent_header": true,
        "page_width": "container-fluid",
        "heading": "{{ page.title }}",
        "heading_size": "h0",
        "color_scheme": "scheme-2",
        "padding_top": 168,
        "padding_bottom": 110,
        "padding_top_tab": 112,
        "padding_bottom_tab": 60,
        "padding_top_mobile": 112,
        "padding_bottom_mobile": 60
      }
    },
    "main": {
      "type": "main-page",
      "settings": {
        "padding_top": 120,
        "padding_bottom": 120,
        "padding_top_tab": 80,
        "padding_bottom_tab": 80,
        "padding_top_mobile": 48,
        "padding_bottom_mobile": 48
      }
    }
  },
  "order": [
    "section-page-header",
    "main"
  ]
}
